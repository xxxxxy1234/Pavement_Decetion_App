<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".detection.MainActivity">

    <!-- 相机预览，占满全屏 -->
    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 检测框叠加层 -->
    <com.example.pavementdetection.detection.DetectionOverlayView
        android:id="@+id/overlayView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 顶部信息栏 -->
    <LinearLayout
        android:id="@+id/infoPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#CC000000"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 第一行：返回 + 标题 + 录制状态 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <ImageButton
                android:id="@+id/btnBackHome"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="10dp"
                android:background="@null"
                android:contentDescription="返回首页"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#FFFFFF" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="路面采集中"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- 录制时长 -->
            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:text="00:00"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- 录制状态指示点 -->
            <TextView
                android:id="@+id/tvRecordDot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● 待机"
                android:textColor="#888888"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- 第二行：配置参数 + 推理帧率 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tvConfig"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="阈值: 3.0 m/s² | 采样率: 50Hz"
                android:textColor="#AAAAAA"
                android:textSize="11sp" />

            <!-- 推理耗时 -->
            <TextView
                android:id="@+id/tvInferMs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="推理: -- ms"
                android:textColor="#888888"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- 第三行：IMU 加速度 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tvAccTal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="acc_tal: 0.00 m/s²"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- IMU 触发状态 -->
            <TextView
                android:id="@+id/tvImuState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IMU 正常"
                android:textColor="#4CAF50"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- 第四行：GPS + 检测计数 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="GPS: 等待定位..."
                android:textColor="#00CC66"
                android:textSize="11sp" />

            <!-- 本次采集检测计数 -->
            <TextView
                android:id="@+id/tvSessionCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="本次: 0 次"
                android:textColor="#888888"
                android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>



    <!-- 底部录制控制区 -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#CC000000"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="16dp"
        android:paddingBottom="32dp"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 通道状态行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="14dp">

            <!-- 通道A状态 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="通道 A"
                    android:textColor="#888888"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvChannelA"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IMU 待机"
                    android:textColor="#555555"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 录制按钮（圆形居中） -->
            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp">

                <View
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/ic_launcher_background"
                    android:alpha="0.3" />

                <Button
                    android:id="@+id/btnRecord"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center"
                    android:background="@drawable/ic_launcher_background"
                    android:text=""
                    android:backgroundTint="#FF3B30" />
            </FrameLayout>

            <!-- 通道B状态 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="通道 B"
                    android:textColor="#888888"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvChannelB"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="视觉 待机"
                    android:textColor="#555555"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="点击开始采集"
            android:textColor="#555555"
            android:textSize="11sp"
            android:id="@+id/tvRecordHint" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>